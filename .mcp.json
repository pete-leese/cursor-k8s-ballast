{
  "mcpServers": {
    "ballast": {
      "command": ".venv/bin/python",
      "args": ["-m", "ballast.mcp_server"],
      "env": {
        "PROMETHEUS_URL": "http://localhost:9090",
        "BALLAST_NAMESPACE": "ballast"
      }
    },
    "grafana": {
      "command": "mcp-grafana",
      "args": ["--disable-write"],
      "env": {
        "GRAFANA_URL": "${GRAFANA_URL}",
        "GRAFANA_SERVICE_ACCOUNT_TOKEN": "${GRAFANA_SERVICE_ACCOUNT_TOKEN}"
      }
    }
  }
}
