  },
  "description": "Ballast RCA evidence — kube-state-metrics + cAdvisor signals for CrashLoopBackOff / OOMKill investigations. Used by Cloud Agent screenshot capture.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "panels": [],
      "title": "Incident signals",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "kube_pod_container_status_waiting_reason{reason=\"CrashLoopBackOff\"} — the BallastServiceCrashLooping alert signal.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [
            { "options": { "0": { "color": "green", "index": 0, "text": "OK" } }, "type": "value" },
            { "options": { "from": 1, "result": { "color": "red", "index": 1, "text": "CRASHLOOP" }, "to": 100 }, "type": "range" }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          },
          "unit": "none"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "id": 1,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "pluginVersion": "10.4.0",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "editorMode": "code",
          "expr": "max(kube_pod_container_status_waiting_reason{namespace=\"$namespace\", container=\"$container\", reason=\"CrashLoopBackOff\"}) or vector(0)",
          "legendFormat": "CrashLoop",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "CrashLoopBackOff",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "kube_pod_container_status_last_terminated_reason{reason=\"OOMKilled\"} — memory limit kill fingerprint.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [
            { "options": { "0": { "color": "green", "index": 0, "text": "OK" } }, "type": "value" },
            { "options": { "from": 1, "result": { "color": "orange", "index": 1, "text": "OOMKilled" }, "to": 100 }, "type": "range" }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "id": 2,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "pluginVersion": "10.4.0",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "editorMode": "code",
          "expr": "max(kube_pod_container_status_last_terminated_reason{namespace=\"$namespace\", container=\"$container\", reason=\"OOMKilled\"}) or vector(0)",
          "legendFormat": "OOMKilled",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Last terminated: OOMKilled",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Total container restarts for the selected service.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 3 }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
