        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "editorMode": "code",
          "expr": "max(kube_pod_container_status_restarts_total{namespace=\"$namespace\", container=\"$container\"}) or vector(0)",
          "legendFormat": "restarts",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Container restarts",
      "type": "stat"
    },
