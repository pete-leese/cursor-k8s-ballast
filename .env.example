# Copy to .env and fill in as needed. Nothing here is required for the local
# deterministic demo (kind + Helm + the ballast engine); these are for the
# read-only Grafana MCP and a live Cursor Cloud Agent investigation.

# Prometheus HTTP API (after: kubectl -n monitoring port-forward
# svc/kube-prometheus-stack-prometheus 9090)
PROMETHEUS_URL=http://localhost:9090
# PROMETHEUS_ALERTS_URL=http://localhost:9090/alerts?state=firing

# Grafana MCP (read-only). Create a Viewer service-account token in Grafana.
GRAFANA_URL=http://localhost:3000
GRAFANA_SERVICE_ACCOUNT_TOKEN=
# Ballast RCA dashboard (provisioned by task grafana:dashboard / setup-cluster)
GRAFANA_DASHBOARD_UID=ballast-rca
# GRAFANA_DASHBOARD_URL=http://localhost:3000/d/ballast-rca/ballast-rca-kubernetes?orgId=1&kiosk
# GRAFANA_USER=admin
# GRAFANA_PASSWORD=admin

# Live Cursor Cloud Agent investigation + RCA discuss chat (optional).
CURSOR_API_KEY=
CURSOR_TARGET_REPO=https://github.com/pete-leese/cursor-k8s-ballast
CURSOR_TARGET_REF=main
# CURSOR_MODEL=composer-2.5

# Evidence screenshots (auto | live | snapshot | off). Needs: task setup:playwright
BALLAST_ARGOCD_SCREENSHOT=auto
ARGOCD_PORT=8080
# Application CR namespace in the UI path (/applications/{ns}/{name}). Not the AppProject.
ARGOCD_APP_NAMESPACE=argocd
ARGOCD_PROJECT=k8s-ballast
# ARGOCD_PASSWORD=   # optional; otherwise read from argocd-initial-admin-secret via kubectl

# Optional: GitHub token for remediation (issue/PR) when macOS keyring is
# unavailable to the Ballast API process. Prefer a classic PAT with repo scope.
# GH_TOKEN=

BALLAST_PROMETHEUS_SCREENSHOT=auto
BALLAST_GRAFANA_SCREENSHOT=auto
