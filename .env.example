# Copy to .env and fill in as needed. Nothing here is required for the local
# deterministic demo (kind + Helm + the ballast engine); these are for the
# read-only Grafana MCP and a live Cursor Cloud Agent investigation.

# Prometheus HTTP API (after: kubectl -n monitoring port-forward
# svc/kube-prometheus-stack-prometheus 9090)
PROMETHEUS_URL=http://localhost:9090

# Grafana MCP (read-only). Create a Viewer service-account token in Grafana.
GRAFANA_URL=http://localhost:3000
GRAFANA_SERVICE_ACCOUNT_TOKEN=

# Live Cursor Cloud Agent investigation (optional).
CURSOR_API_KEY=
CURSOR_TARGET_REPO=https://github.com/pete-leese/cursor-k8s-ballast
CURSOR_TARGET_REF=main
